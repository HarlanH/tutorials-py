# Copy this file to .env and fill in the key for the provider you use.
#   cp .env.example .env
# Then run: uv run main.py
#
# Switch providers by editing LLM_PROVIDER and LLM_MODEL below. No code changes.

LLM_PROVIDER=kilo
LLM_MODEL=nex-agi/nex-n2-pro:free

# Kilo Gateway
KILO_BASE_URL=https://api.kilo.ai/api/gateway
KILO_API_KEY=

# Ollama (only needed if LLM_PROVIDER=ollama)
# LLM_MODEL=qwen2.5-coder:7b
