# Copy this file to .env and fill in the key for the provider you use:
#   cp .env.example .env
# main.py loads .env automatically, then run: uv run main.py
#
# Switch providers by editing LLM_PROVIDER and LLM_MODEL below. No code changes.

LLM_PROVIDER=fireworks
LLM_MODEL=accounts/fireworks/models/gpt-oss-120b

# Set the key that matches LLM_PROVIDER (you only need that one):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
